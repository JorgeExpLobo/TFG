rsion":3.4,"position":[-560,384],"id":"a6b3895d-8739-4c99-8126-202900e4d669","name":"Switch"},{"parameters":{"promptType":"define","text":"={{ $json.message_lower }}","hasOutputParser":true,"messages":{"messageValues":[{"message":"You are a specialized Cooking Assistant Intent Classifier. Your task is to analyze user messages and extract ALL applicable intents.  ### RULES: 1. Return ONLY a valid JSON object. 2. If multiple intents are present, include ALL of them in the \"intents\" array. 3. Use \"unknown\" ONLY if the message is completely unrelated to cooking or kitchen management.  ### INTENT DEFINITIONS & EXAMPLES: - ingredient_add: Adding items to inventory or a recipe (e.g., \"Añade 3 tomates\", \"Pon manzanas en la lista\"). - ingredient_remove: Deleting items (e.g., \"Quita la leche\", \"Borra el arroz\"). - ingredient_update: Changing quantities or details (e.g., \"Cambia los 3 tomates por 5\"). - recipe_search: Looking for a specific recipe by name (e.g., \"Busca cómo hacer Paella\"). - recipe_suggest: Asking for ideas based on ingredients or preferences (e.g., \"Dime una receta con estas manzanas\"). - diet_generate: Requesting structured meal plans or specific diets (e.g., \"Hazme una dieta keto\", \"Plan de comidas vegano\"). - shopping_list: Managing a grocery list (e.g., \"Qué tengo que comprar\", \"Añade esto a mi lista de la compra\").  ### EXAMPLE MULTI-INTENT: User: \"Añade 4 manzanas fuji y dime una receta. También hazme una dieta keto.\" Output: { \"intents\": [\"ingredient_add\", \"recipe_suggest\", \"diet_generate\"] }"}]},"batching":{}},"type":"@n8n/n8n-nodes-langchain.chainLlm","typeVersion":1.9,"position":[-1184,464],"id":"db2eece6-d981-421c-b6c1-2c4fd3697954","name":"Basic LLM Chain"},{"parameters":{"model":{"__rl":true,"value":"gpt-4o-mini","mode":"list","cachedResultName":"gpt-4o-mini"},"builtInTools":{},"options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatOpenAi","typeVersion":1.3,"position":[-1184,688],"id":"56ec99fa-4dd7-4daf-b607-256